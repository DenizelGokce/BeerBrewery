@page "/beers/create"
@inject IBeerService BeerService
@inject NavigationManager Navigation
@using BeerBrewery.Application.Interfaces
@using BeerBrewery.Application.DTOs.Beer
@using BeerBrewery.Application.DTOs.Ingredient
@using BeerBrewery.Application.DTOs.Ingredient.Enums

@rendermode InteractiveServer

<div class="glass-page">

    <div class="hero">
        <h1>Create Beer</h1>
        <p>Design a new brew like a professional brewery system</p>
    </div>

    @if (_errorMessage is not null)
    {
        <div class="glass-alert">
            @_errorMessage
        </div>
    }

    <EditForm Model="_dto" OnValidSubmit="HandleSubmit" FormName="CreateBeerForm">
        <DataAnnotationsValidator />

        <!-- GLASS CARD -->
        <div class="glass-card">

            <h3>Beer details</h3>

            <div class="grid">

                <div class="field">
                    <label>Name</label>
                    <InputText class="glass-input" @bind-Value="_dto.Name" />
                    <ValidationMessage For="@(() => _dto.Name)" />
                </div>

                <div class="field">
                    <label>Alcohol %</label>
                    <InputNumber class="glass-input" @bind-Value="_dto.AlcoholPercentage" />
                    <ValidationMessage For="@(() => _dto.AlcoholPercentage)" />
                </div>

            </div>

            <div class="field">
                <label>Description</label>
                <InputTextArea class="glass-input" @bind-Value="_dto.Description" />
                <ValidationMessage For="@(() => _dto.Description)" />
            </div>

        </div>

        <!-- INGREDIENTS -->
        <div class="glass-card">

            <div class="card-head">
                <h3>Ingredients</h3>

                <button type="button"
                        class="glass-btn"
                        @onclick="AddIngredient">
                    + Add
                </button>
            </div>

            @if (!_dto.Ingredients.Any())
            {
                <p class="muted">No ingredients yet — start building your recipe.</p>
            }

            @foreach (var ingredient in _dto.Ingredients)
            {
                <div class="ingredient-glass">

                    <InputText class="glass-input"
                               placeholder="Name"
                               @bind-Value="ingredient.Name" />

                    <InputSelect class="form-control" @bind-Value="ingredient.Type">
                        @foreach (var type in Enum.GetValues<IngredientType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </InputSelect>

                    <InputText class="glass-input"
                               placeholder="Quantity"
                               @bind-Value="ingredient.Quantity" />

                    <button type="button"
                            class="glass-delete"
                            @onclick="() => RemoveIngredient(ingredient)">
                        ✕
                    </button>
                </div>
            }

        </div>

        <!-- ACTIONS -->
        <div class="actions">

            <a href="/beers" class="glass-btn ghost">Cancel</a>

            <button type="submit" class="glass-btn primary">
                Create Beer
            </button>

        </div>

    </EditForm>
</div>

@code {
    private CreateBeerDto _dto = new();
    private string? _errorMessage;

    private void AddIngredient()
    {
        _dto.Ingredients.Add(new CreateIngredientDto());
    }

    private void RemoveIngredient(CreateIngredientDto ingredient)
    {
        _dto.Ingredients.Remove(ingredient);
    }

    private async Task HandleSubmit()
    {
        try
        {
            _errorMessage = null;
            await BeerService.CreateAsync(_dto);
            Navigation.NavigateTo("/beers");
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
    }
}