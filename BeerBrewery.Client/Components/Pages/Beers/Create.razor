@page "/beers/create"
@inject IBeerService BeerService
@inject NavigationManager Navigation
@using BeerBrewery.Application.Interfaces
@using BeerBrewery.Application.DTOs.Beer
@using BeerBrewery.Application.DTOs.Ingredient
@rendermode InteractiveServer

<div class="page-header">
    <div>
        <h1>Create Beer</h1>
        <p class="muted">Build your recipe</p>
    </div>
</div>

@if (_errorMessage is not null)
{
    <div class="alert-danger">@_errorMessage</div>
}

<EditForm Model="_dto" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="form-grid">
        <div class="form-group">
            <label>Name</label>
            <InputText class="form-control" @bind-Value="_dto.Name" />
        </div>

        <div class="form-group">
            <label>Alcohol %</label>
            <InputNumber class="form-control" @bind-Value="_dto.AlcoholPercentage" />
        </div>
    </div>

    <div class="form-group">
        <label>Description</label>
        <InputTextArea class="form-control" @bind-Value="_dto.Description" />
    </div>

    <h3>Ingredients</h3>

    @if (_dto.Ingredients.Count == 0)
    {
        <p class="muted">No ingredients yet. Add one below.</p>
    }

    @foreach (var ingredient in _dto.Ingredients)
    {
        <div class="ingredient-card">
            <InputText placeholder="Name" class="form-control" @bind-Value="ingredient.Name" />
            <InputText placeholder="Type" class="form-control" @bind-Value="ingredient.Type" />
            <InputText placeholder="Quantity" class="form-control" @bind-Value="ingredient.Quantity" />
        </div>
    }

    <div class="button-row">
        <button type="button" class="btn btn-secondary" @onclick="AddIngredient">
            + Add Ingredient
        </button>

        <button type="submit" class="btn btn-primary">
            Create Beer
        </button>

        <a href="/beers" class="btn btn-ghost">
            Cancel
        </a>
    </div>
</EditForm>

@code {
    private CreateBeerDto _dto = new();
    private string? _errorMessage;

    private void AddIngredient()
    {
        _dto.Ingredients.Add(new CreateIngredientDto());
    }

    private async Task HandleSubmit()
    {
        try
        {
            _errorMessage = null;
            await BeerService.CreateAsync(_dto);
            Navigation.NavigateTo("/beers");
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
    }
}