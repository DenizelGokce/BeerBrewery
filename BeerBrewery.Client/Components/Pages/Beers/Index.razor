@page "/beers"
@inject IBeerService BeerService
@using BeerBrewery.Application.Interfaces
@using BeerBrewery.Application.DTOs.Beer
@rendermode InteractiveServer

<div class="beer-page">

    <div class="header">
        <div>
            <h1>Beers</h1>
            <p class="muted">Your brewery catalog</p>
        </div>

        <a href="/beers/create" class="glass-btn primary">
            + Add Beer
        </a>
    </div>

    @if (_beers is null)
    {
        <p class="muted">Loading...</p>
    }
    else if (!_beers.Any())
    {
        <div class="empty-state">
            <h3>No beers found</h3>
            <p class="muted">Start by creating your first brew.</p>
        </div>
    }
    else
    {
        <div class="beer-grid">

            @foreach (var beer in _beers)
            {
                <div class="beer-card">

                    <div class="beer-top">
                        <h3>@beer.Name</h3>
                        <span class="abv">@beer.AlcoholPercentage% ABV</span>
                    </div>

                    <p class="desc">@beer.Description</p>

                    <div class="beer-actions">
                        <a href="/beers/@beer.Id" class="glass-btn">
                            Details
                        </a>
                    </div>

                </div>
            }

        </div>
    }

</div>

@code {
    private IEnumerable<BeerDto>? _beers;

    protected override async Task OnInitializedAsync()
    {
        _beers = await BeerService.GetAllAsync();
    }
}