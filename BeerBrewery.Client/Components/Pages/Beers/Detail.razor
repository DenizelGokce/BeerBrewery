@page "/beers/{Id:guid}"
@inject IBeerService BeerService
@inject NavigationManager Navigation
@using BeerBrewery.Application.Interfaces
@using BeerBrewery.Application.DTOs.Beer
@rendermode InteractiveServer

<div class="detail-page">

    @if (_beer is null)
    {
        <p class="muted">Loading beer data...</p>
    }
    else
    {
        <!-- HERO CARD -->
        <div class="hero-card">

            <div class="hero-top">
                <h1>@_beer.Name</h1>
                <span class="badge">@_beer.AlcoholPercentage% ABV</span>
            </div>

            <p class="desc">@_beer.Description</p>

            <div class="actions">
                <a href="/beers" class="glass-btn">Back</a>

                <button class="glass-btn danger"
                        @onclick="DeleteBeer">
                    Delete Beer
                </button>
            </div>

        </div>

        <!-- INGREDIENTS -->
        <div class="section-card">

            <h3>Ingredients</h3>

            @if (!_beer.Ingredients.Any())
            {
                <p class="muted">No ingredients in this recipe.</p>
            }
            else
            {
                <div class="ingredient-grid">

                    @foreach (var ingredient in _beer.Ingredients)
                    {
                        <div class="ingredient-card">

                            <div class="ingredient-name">
                                @ingredient.Name
                            </div>

                            <div class="ingredient-meta">
                                <span>@ingredient.Type</span>
                                <span class="qty">@ingredient.Quantity</span>
                            </div>

                        </div>
                    }

                </div>
            }

        </div>
    }

</div>

@code {
    [Parameter] public Guid Id { get; set; }
    private BeerDto? _beer;

    protected override async Task OnInitializedAsync()
    {
        _beer = await BeerService.GetByIdAsync(Id);
    }

    private async Task DeleteBeer()
    {
        await BeerService.DeleteAsync(Id);
        Navigation.NavigateTo("/beers");
    }
}