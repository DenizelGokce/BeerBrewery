@page "/ingredients"
@inject IBeerService BeerService
@using BeerBrewery.Application.Interfaces
@using BeerBrewery.Application.DTOs.Beer
@using BeerBrewery.Application.DTOs.Ingredient.Enums
@rendermode InteractiveServer

<div class="glass-page">

    <div class="hero">
        <h1>Ingredients</h1>
        <p>Everything that goes into your beers</p>
    </div>

    @if (_beers is null)
    {
        <div class="glass-card">Loading...</div>
    }
    else
    {
        @foreach (var beer in _beers)
        {
            @foreach (var ing in beer.Ingredients)
            {
                <div class="glass-card ingredient-glass">

                    <div>
                        <label>Name</label>
                        <div>@ing.Name</div>
                    </div>

                    <div>
                        <label>Type</label>
                        <div>@ing.Type</div>
                    </div>

                    <div>
                        <label>Quantity</label>
                        <div>@ing.Quantity</div>
                    </div>

                    <div>
                        <label>Beer</label>
                        <div>@beer.Name</div>
                    </div>

                </div>
            }
        }
    }

</div>

@code {
    private IEnumerable<BeerDto>? _beers;

    protected override async Task OnInitializedAsync()
    {
        _beers = await BeerService.GetAllAsync();
    }
}